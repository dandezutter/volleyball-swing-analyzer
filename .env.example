# Copy this to .env.local for local Netlify dev (netlify dev command)
# NEVER commit .env.local — it's in .gitignore
#
# Get your Claude API key from: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional: override API base URL for Capacitor/native app builds
# VITE_API_BASE_URL=https://your-site.netlify.app
